# dfps - Dynamic FPS Controller daemon
#
# Native init integration for the tri-module (Magisk / KernelSU / Axeron)
# root daemon. The shipped module normally launches through service.sh at
# boot; this file documents the equivalent init.rc entry for environments
# that prefer a direct init service (e.g. a system/etc/init/ drop-in or a
# $MODPATH/service.d/ file processed by the root manager's init-trigger).
#
# The daemon:
#   - runs as root (required for /dev/input and the uevent netlink socket)
#   - sets PR_SET_NO_NEW_PRIVS and PR_SET_KEEP_CAPS at startup
#   - exits gracefully when a critical Binder service dies, expecting the
#     supervisor (init) to respawn it

service dfps /data/local/tmp/dfps/dfps
    class main
    user root
    group root input
    # 'critical' restarts the service on exit but throttles restart storms
    # so a broken device build cannot fast-loop into a boot loop.
    critical
    # Capabilities the daemon needs. It keeps CAP_NET_ADMIN (uevent netlink)
    # and CAP_SYS_ADMIN (input/sysfs control) via PR_SET_KEEP_CAPS; the
    # full reduction is handled here / by SELinux, not in-process.
    capabilities NET_ADMIN SYS_ADMIN
    # If SELinux is enforcing, the domain must allow binder transacts, the
    # uevent netlink socket, and /dev/input access. The 'su' domain is the
    # common permissive fallback for root modules; replace with a dedicated
    # dfps domain in a hardened build.
    seclabel u:r:su:s0
    # Disable the default SIGTERM-on-shutdown delay behavior is unnecessary;
    # init sends SIGTERM and the daemon unwinds cleanly.
